# StudEx Hermes Command — environment template
# Copy to .env and fill in. NEVER commit .env.

# --- Console gate ---
NALEDI_PASSWORD=12345

# --- LLM (sales agent + swarm) ---
# Provider order: local | cloud | auto (default auto = try local LM Studio first, then cloud).
LLM_PROVIDER=auto
# Local models via LM Studio / Ollama (OpenAI-compatible). For other machines on the LAN,
# run LM Studio's server bound to 0.0.0.0 and use the host's LAN IP, e.g. http://192.168.1.50:1234/v1
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_API_KEY=lm-studio
LOCAL_MODEL=local-model
# Cloud API fallback (OpenRouter by default; any OpenAI-compatible endpoint works).
CLOUD_MODEL_API_KEY=
CLOUD_MODEL_BASE_URL=https://openrouter.ai/api/v1
SALES_AGENT_MODEL=moonshotai/kimi-k2

# --- Embeddings (for Pinecone ingest + retrieval) ---
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# --- Pinecone RAG (Obsidian vault knowledge base) ---
PINECONE_API_KEY=
# Index host looks like: https://<index-name>-<project>.svc.<region>.pinecone.io
PINECONE_INDEX_HOST=
PINECONE_NAMESPACE=studex-vault

# --- Speech-to-text (live call mode) ---
STT_API_KEY=
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1

# --- ElevenLabs text-to-speech (ADA's voice) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --- Twilio WhatsApp (sales channel) ---
# Use either API Key auth (preferred — revocable per key) or Account SID + Auth Token.
TWILIO_ACCOUNT_SID=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_AUTH_TOKEN=
# WhatsApp number with prefix, e.g. whatsapp:+14155238886 (sandbox) or whatsapp:+27...
TWILIO_WHATSAPP_NUMBER=

# --- Session store (WhatsApp conversation memory) ---
# Upstash-compatible Redis REST. Unset = in-memory fallback (lost on restart).
REDIS_REST_URL=
REDIS_REST_TOKEN=

# --- Meeting/call memory ingestion ---
# Optional shared secret; when set, POST /api/memory/ingest requires header X-Ingest-Secret.
MEMORY_INGEST_SECRET=

# --- Admin (lead list, internal endpoints) ---
# Optional; when set, GET /api/onboard requires header X-Admin-Key.
ADMIN_API_KEY=
