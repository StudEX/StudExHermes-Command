# Shopify API Credentials (DO NOT COMMIT THIS FILE)
# Copy to .env and fill in actual values

# Store 1: studexmeat.myshopify.com
SHOPIFY_STORE_1_DOMAIN=studexmeat.myshopify.com
SHOPIFY_STORE_1_ACCESS_TOKEN=shpat_your_token_here_store1
SHOPIFY_STORE_1_API_KEY=your_api_key_store1
SHOPIFY_STORE_1_API_SECRET=your_api_secret_store1
SHOPIFY_STORE_1_WEBHOOK_SECRET=your_webhook_secret_store1

# Store 2: studex-meat.myshopify.com
SHOPIFY_STORE_2_DOMAIN=studex-meat.myshopify.com
SHOPIFY_STORE_2_ACCESS_TOKEN=shpat_your_token_here_store2
SHOPIFY_STORE_2_API_KEY=your_api_key_store2
SHOPIFY_STORE_2_API_SECRET=your_api_secret_store2
SHOPIFY_STORE_2_WEBHOOK_SECRET=your_webhook_secret_store2

# Webhook Configuration
WEBHOOK_ENDPOINT_STORE_1=https://studex-meat-vm.fly.dev/webhooks/store1
WEBHOOK_ENDPOINT_STORE_2=https://studex-meat-vm.fly.dev/webhooks/store2

# Database
POSTGRES_URL=postgresql://user:password@host:5432/database

# Redis
REDIS_URL=redis://host:6379

# Node Environment
NODE_ENV=development
API_VERSION=2024-01
